# ==============================================================================
# STUDYMATE API ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy this file to '.env' and fill in the required variables.
# 
# Pydantic Settings automatically maps these values to the Settings object in 
# 'core/config.py'. All values listed under "OPTIONAL OVERRIDES" have defaults 
# hardcoded in the codebase, but can be uncommented and changed here if needed.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. REQUIRED CONFIGURATION (App will crash at startup if missing)
# ------------------------------------------------------------------------------

# Database connection URL (FastAPI automatically coerces this to use asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/studymate

# Random 32+ character key used to sign JWT auth tokens
JWT_SECRET_KEY=your-very-long-random-secret-key-at-least-32-chars

# Google AI Studio Gemini API Key
GOOGLE_API_KEY=your-google-api-key

# Qdrant Vector DB Cloud/Local Connection Details
QDRANT_URL=https://your-cluster-id.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key


# ------------------------------------------------------------------------------
# 1b. ADMIN CONFIGURATION
# ------------------------------------------------------------------------------

# The one account auto-promoted to super_admin (full admin + pro) on signup/login.
# Leave blank to disable the super-admin auto-assignment entirely.
SUPER_ADMIN_EMAIL=your-email@example.com


# ------------------------------------------------------------------------------
# 2. OPTIONAL OVERRIDES (Defaults are already hardcoded in the codebase)
# ------------------------------------------------------------------------------

# --- General API Settings ---
# DEBUG=false                                                 # Enable verbose logs and debug mode
# APP_NAME="StudyMate API"                                    # Swagger UI title and health name
# APP_VERSION=1.0.0                                           # Swagger UI version string
# CORS_ORIGINS=http://localhost:3000                          # Comma-separated list of allowed origins

# --- JWT / Auth Settings ---
# JWT_ALGORITHM=HS256                                         # Signature algorithm for auth tokens
# ACCESS_TOKEN_EXPIRE_MINUTES=30                              # Access token lifetime
# REFRESH_TOKEN_EXPIRE_DAYS=7                                 # Refresh token lifetime

# --- Google Gemini Generation Models ---
# GEMINI_PRIMARY_MODEL=gemini-3.5-flash                       # Primary LLM used for high-tier requests
# GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite                 # Fallback LLM on 429 rate limit / failover
# GEMINI_MEDIUM_MODEL=gemini-3.5-flash                        # LLM override for medium performance tier
# GEMINI_LOW_MODEL=gemini-3.1-flash-lite                      # LLM override for low performance tier
# GENERATION_TEMPERATURE=0.3                                  # Model creativity (lower is more factual)
# MAX_RETRIES=1                                               # Primary-model transient-error retries before fallback
# RETRY_DELAY_SECONDS=2                                       # Sleep duration between generation retries
# QUIZ_REPROMPT_SINGLE_ATTEMPT=true                           # Quiz reformat reprompt = single call (caps LLM calls at 4)

# --- Embedding & Vector DB Settings ---
# EMBEDDING_MODEL=models/gemini-embedding-2                   # Model used to vectorize chunks/queries
# EMBEDDING_BATCH_SIZE=50                                     # Batch size for embedding API calls
# COLLECTION_NAME=studymate_chunks                            # Qdrant collection name
# VECTOR_SIZE=3072                                            # Vector dimensions (embedding-2 is 3072)
# UPSERT_BATCH_SIZE=100                                       # Points per batch sent to Qdrant

# --- PDF Chunking & Upload Settings ---
# DEFAULT_CHUNK_SIZE=500                                      # Target chunk size in tokens
# DEFAULT_CHUNK_OVERLAP=50                                    # Token overlap between chunks
# MIN_CHUNK_LENGTH=50                                         # Minimum characters to persist a chunk
# MAX_UPLOAD_SIZE_MB=20                                       # Maximum allowed PDF upload size

# --- RAG Retrieval Settings ---
# DEFAULT_TOP_K=5                                             # Default chunks retrieved from vector store
# RETRIEVAL_SIMILARITY_THRESHOLD=0.60                         # Minimum similarity score required

# --- Rolling 24h User Token Quotas ---
# FREE_DAILY_TOKEN_LIMIT=50000                                # Max tokens per day for free tier users
# PRO_DAILY_TOKEN_LIMIT=500000                                # Max tokens per day for pro tier users

# --- Quiz Generation Limits ---
# DEFAULT_QUIZ_QUESTIONS=5                                    # Default questions count for a quiz
# MAX_QUIZ_QUESTIONS=30                                       # Hard limit on generated quiz questions
